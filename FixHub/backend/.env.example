# Environment Variables Configuration
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env file to git - add to .gitignore

# Server Configuration
PORT=3000
NODE_ENV=development
HTTPS=false

# Database Configuration
MONGO_URI=mongodb://localhost:27017/fixhub

# Authentication
# IMPORTANT: Generate a strong random secret (minimum 32 characters)
# You can generate one using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-very-long-random-secret-key-minimum-32-characters-CHANGE-IN-PRODUCTION

# Frontend API Base URL (for CORS)
FRONTEND_URL=http://localhost:5500

# Optional: Payment Gateway Keys (if using Stripe/PayPal)
# STRIPE_SECRET_KEY=your_stripe_secret_key
# STRIPE_PUBLIC_KEY=your_stripe_public_key
# PAYPAL_CLIENT_ID=your_paypal_client_id
# PAYPAL_SECRET=your_paypal_secret

# Optional: Email Configuration (for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@fixhub.com

# Optional: File Upload
# MAX_FILE_SIZE=5242880  # 5MB in bytes
# UPLOAD_DIR=./uploads

# Optional: Session Configuration
# SESSION_SECRET=your-session-secret-key
# SESSION_TIMEOUT=86400000  # 24 hours in milliseconds
